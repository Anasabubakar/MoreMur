PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Neon Postgres only — use connection string from Neon Console → Connect
# Do NOT enable Neon Auth; Murmur uses custom auth in this API.
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Auth
JWT_SECRET=change-me-use-openssl-rand-hex-32
ADMIN_KEY=dev-admin-key

# CORS — Vercel URL in production
CORS_ORIGIN=http://localhost:3000

# Resend — OTP emails (optional in dev: codes log to console)
RESEND_API_KEY=re_xxxxxxxx
OTP_FROM_EMAIL=Murmur <auth@yourdomain.com>
