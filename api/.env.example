PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Neon Postgres — Neon Console → Project → Connect → copy "Connection string"
# Paste the ENTIRE value (password is URL-encoded). Do not enable Neon Auth for this app.
# After password reset, replace this line completely — old URLs keep failing.
# Troubleshooting: npm run db:check
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Auth
JWT_SECRET=change-me-use-openssl-rand-hex-32
ADMIN_KEY=dev-admin-key

# CORS — Vercel URL in production
CORS_ORIGIN=http://localhost:3000

# Resend — OTP emails (optional in dev: codes log to console)
RESEND_API_KEY=re_xxxxxxxx
OTP_FROM_EMAIL=Murmur <auth@yourdomain.com>
