PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Neon Postgres — Console → Connect → copy "Connection string" (pooled is fine)
# Murmur uses Neon's WebSocket driver when the host contains neon.tech (avoids ECONNRESET on some networks).
# Troubleshooting: npm run db:check
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Auth
JWT_SECRET=change-me-use-openssl-rand-hex-32
ADMIN_KEY=dev-admin-key

# CORS — must match Vercel URL exactly (no trailing slash)
CORS_ORIGIN=https://moremur.vercel.app

# Resend — see docs/RESEND.md (do NOT use placeholder domains)
# Dev: omit RESEND_API_KEY → OTP printed in terminal
RESEND_API_KEY=re_xxxxxxxx
# Sandbox: only sends to the email on your Resend account
OTP_FROM_EMAIL=Murmur <onboarding@resend.dev>
# Prod: use a VERIFIED domain you own, e.g. Murmur <noreply@mail.learn2earn.ng>
